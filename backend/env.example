OLLAMA_BASE_URL=http://127.0.0.1:11434
# Match a name from `ollama list` (e.g. llama3.1:8b, mistral:7b, phi3:mini, gemma3:1b)
OLLAMA_MODEL=llama3.1:8b
# Refinement pass (default qwen2.5:7b). Set to empty to disable. ollama pull qwen2.5:7b
OLLAMA_REFINEMENT_MODEL=qwen2.5:7b
# Max characters sent to the LLM (split across primary + extra sample PDFs when you add those in the UI)
LLM_MAX_CHARS=12000
LLM_NUM_CTX=4096
OLLAMA_HTTP_TIMEOUT=900
# 1 = Ollama /api/chat + JSON Schema structured output (recommended; needs recent Ollama). 0 = OpenAI API only.
OLLAMA_STRUCTURED_JSON=1
OCR_USE_GPU=1
# scan | auto | embedded
EXTRACTION_MODE=scan
# paddle (PP-Structure) | easyocr | docling (default; install requirements-docling.txt — else server falls back to easyocr)
OCR_ENGINE=docling
OCR_DPI=300
MAX_UPLOAD_MB=50

# --- Graph RAG (Faiss index under graph-db/vector-index + optional Neo4j expand) ---
# Build index: cd graph-db && pip install -r requirements.txt && python scripts/vector_index.py build
GRAPH_RAG_ENABLED=0
# GRAPH_RAG_INDEX_DIR=C:\path\to\ml_pattern\graph-db\vector-index
GRAPH_RAG_VECTOR_K=12
GRAPH_RAG_MAX_CONTEXT_CHARS=20000
# Hybrid retrieval (default on): BM25 + 2 dense branches + RRF. Set to 0 for legacy cosine-only.
GRAPH_RAG_HYBRID=1
GRAPH_RAG_RRF_K=60
GRAPH_RAG_DENSE_BRANCH_K=48
GRAPH_RAG_BM25_BRANCH_K=48
GRAPH_RAG_DOC_SNIPPET_CHARS=1200
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# --- Agentic workflow (LangChain; optional LLM summary in Agent 1) ---
# AGENT1_MODEL=llama3.1:8b
# AGENT2_MODEL=qwen2.5:7b
# AGENT_OCR_CHUNK_K=6
# AGENT_LLM_SUMMARY=0

# --- GPU / Docling (see GPU_SETUP.md in repo root) ---
# OCR_USE_GPU=1
# OCR_ENGINE=easyocr
# Point Hugging Face / Docling model cache to a large disk if needed:
# HF_HOME=/data/huggingface
